{
  "manifest_version": 3,
  "name": "Ecoute Capture",
  "version": "0.1.0",
  "description": "Capture DOM context from any page and file AI-enriched GitHub issues.",
  "permissions": ["activeTab", "storage", "scripting", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ecoute Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
